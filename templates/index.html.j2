{% extends "base.html.j2" %}
{% set prefectures = [
  "北海道","青森県","岩手県","宮城県","秋田県","山形県","福島県",
  "茨城県","栃木県","群馬県","埼玉県","千葉県","東京都","神奈川県",
  "新潟県","富山県","石川県","福井県","山梨県","長野県",
  "岐阜県","静岡県","愛知県","三重県",
  "滋賀県","京都府","大阪府","兵庫県","奈良県","和歌山県",
  "鳥取県","島根県","岡山県","広島県","山口県",
  "徳島県","香川県","愛媛県","高知県",
  "福岡県","佐賀県","長崎県","熊本県","大分県","宮崎県","鹿児島県","沖縄県"
] %}
{% block title %}補助金まとめ（{{ total }}件掲載）{% endblock %}

{% block head_extra %}
<script type="application/ld+json">{{ index_ld_data|tojson }}</script>
{% endblock %}

{% block content %}
<section class="intro">
  <h1>補助金まとめ</h1>
  <p>jGrants の公募中補助金 <strong>{{ total }}</strong> 件を毎日自動更新中。</p>
</section>

<section class="filters" aria-label="絞り込み">
  <details open>
    <summary>絞り込み</summary>
    <div class="filter-group">
      <span class="filter-label">業種</span>
      {% for tag in ["IT", "製造業", "飲食", "農業", "建設", "小売", "医療", "教育", "全業種"] %}
      <label><input type="checkbox" data-filter="industry" value="{{ tag }}"> {{ tag }}</label>
      {% endfor %}
    </div>
    <div class="filter-group">
      <span class="filter-label">規模</span>
      {% for tag in ["個人事業主", "小規模事業者", "中小企業", "大企業", "全規模"] %}
      <label><input type="checkbox" data-filter="size" value="{{ tag }}"> {{ tag }}</label>
      {% endfor %}
    </div>
    <div class="filter-group">
      <span class="filter-label">用途</span>
      {% for tag in ["設備投資", "IT導入", "人材育成", "販路開拓", "研究開発", "省エネ", "海外展開"] %}
      <label><input type="checkbox" data-filter="purpose" value="{{ tag }}"> {{ tag }}</label>
      {% endfor %}
    </div>
    <div class="filter-group">
      <span class="filter-label">地域</span>
      <select id="filter-prefecture">
        <option value="all">全件</option>
        <option value="全国">全国対象のみ</option>
        {% for pref in prefectures %}
        <option value="{{ pref }}">{{ pref }}</option>
        {% endfor %}
      </select>
    </div>
    <div class="filter-group">
      <span class="filter-label">締切</span>
      <select id="filter-deadline">
        <option value="all">全件</option>
        <option value="7">7日以内</option>
        <option value="14">14日以内</option>
        <option value="30">1ヶ月以内</option>
        <option value="90">3ヶ月以内</option>
      </select>
    </div>
    <div class="filter-group">
      <span class="filter-label">並び順</span>
      <select id="sort-order">
        <option value="new">新着順</option>
        <option value="deadline">締切が近い順</option>
        <option value="amount">補助額が多い順</option>
      </select>
    </div>
    <div class="filter-actions">
      <button type="button" id="reset-filters">リセット</button>
      <button type="button" id="copy-link" title="この絞り込み条件のURLをクリップボードにコピーします">この条件のURLをコピー</button>
      <a href="#" id="open-wizard" class="text-link">条件を質問形式で設定する</a>
    </div>
    <div class="filter-actions filter-actions-secondary">
      <label class="unread-toggle">
        <input type="checkbox" id="unread-only"> 未読のみ表示 <small>(既読: <span id="visited-count">0</span>件)</small>
      </label>
      <button type="button" id="reset-visited" class="text-button">既読をリセット</button>
      <small class="persist-note">条件・既読履歴はブラウザに自動保存されます</small>
    </div>
  </details>
</section>

{# === オンボーディング・ウィザード (初回訪問時のみ表示) === #}
<div id="wizard-modal" class="wizard-modal hidden" role="dialog" aria-modal="true" aria-labelledby="wizard-title">
  <div class="wizard-overlay"></div>
  <div class="wizard-dialog">
    <header class="wizard-header">
      <h2 id="wizard-title">あなたに合う補助金を絞り込みます</h2>
      <button type="button" class="wizard-skip" aria-label="ウィザードを閉じる">スキップ ×</button>
    </header>
    <div class="wizard-body"><!-- JSが描画 --></div>
    <footer class="wizard-footer">
      <button type="button" class="wizard-back">← 戻る</button>
      <button type="button" class="wizard-next">次へ →</button>
    </footer>
  </div>
</div>

<section id="results" class="card-list" aria-label="補助金一覧">
  {% for s in subsidies %}
  <article
    class="card"
    data-id="{{ s.id }}"
    data-industry="{{ s.industry_tags|join(',') }}"
    data-size="{{ s.size_tags|join(',') }}"
    data-purpose="{{ s.purpose_tags|join(',') }}"
    data-prefecture="{{ s.prefecture or '' }}"
    data-deadline="{{ s.deadline or '' }}"
    data-amount-max="{{ s.amount_max or 0 }}"
    data-first-seen="{{ s.first_seen_at or '' }}"
    data-urgency="{{ s.urgency or 1 }}">
    <header class="card-head">
      {% if s.is_new %}<span class="badge badge-new">新着</span>{% endif %}
      {% if s.urgency and s.urgency >= 4 %}<span class="badge badge-urgent">締切間近</span>{% endif %}
      <h2 class="card-title">{{ s.title }}</h2>
    </header>
    <ul class="tag-list">
      {% for t in s.industry_tags[:3] %}<li class="tag">{{ t }}</li>{% endfor %}
      {% for t in s.size_tags[:2] %}<li class="tag tag-size">{{ t }}</li>{% endfor %}
    </ul>
    <dl class="card-meta">
      {% if s.amount_text %}<dt>補助額</dt><dd>{{ s.amount_text }}</dd>{% endif %}
      {% if s.subsidy_rate_official %}<dt>補助率</dt><dd>{{ s.subsidy_rate_official }}</dd>{% endif %}
      {% if s.deadline %}<dt>締切</dt><dd>{{ s.deadline }}</dd>{% endif %}
      {% if s.prefecture %}<dt>地域</dt><dd>{{ s.prefecture }}</dd>{% endif %}
    </dl>
    {% if s.key_warnings %}
    <p class="card-warning"><span class="warning-icon" aria-hidden="true">⚠</span> {{ s.key_warnings[0] }}</p>
    {% endif %}
    {% if s.plain_summary %}
    <p class="card-summary"><span class="ai-label">AI要約</span> {{ s.plain_summary }}</p>
    {% endif %}
    <p class="card-actions">
      <a class="btn" href="subsidies/{{ s.id }}.html">詳細を見る →</a>
    </p>
  </article>
  {% else %}
  <p class="empty">表示できる補助金がまだありません。</p>
  {% endfor %}
</section>

<p id="no-match" class="empty hidden">条件に一致する補助金がありません。</p>
{% endblock %}

{% block scripts %}
{# wizard.js を filter.js より先に読み込む: filter.js が history.replaceState で
   URL を書き換える前に wizard.js が ?wizard=1 を検出できるようにするため #}
<script src="wizard.js"></script>
<script src="filter.js"></script>
<script src="visited.js"></script>
{% endblock %}
